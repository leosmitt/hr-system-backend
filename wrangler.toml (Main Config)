# packages/backend/wrangler.toml
name = "hr-system-backend"
main = "src/index.js"
compatibility_date = "2024-01-15"

# Environment variables
[vars]
NODE_ENV = "production"
JWT_SECRET = "CHANGE_THIS_TO_RANDOM_SECRET_KEY"
JWT_EXPIRE = "7d"
ADMIN_USERNAME = "admin"

# D1 Database
[[d1_databases]]
binding = "DB"
database_name = "hr-system-db"
database_id = "your-d1-database-id"
migrations_dir = "../../migrations"

# KV for sessions
[[kv_namespaces]]
binding = "SESSIONS"
id = "your-kv-namespace-id"

# AI Settings (optional)
[vars]
OPENAI_API_KEY = ""
GEMINI_API_KEY = ""
ANTHROPIC_API_KEY = ""
DEEPSEEK_API_KEY = ""

# Environment specific settings
[env.production]
vars = { NODE_ENV = "production" }
routes = [
  { pattern = "api.yourdomain.com/*", zone_id = "your-zone-id" }
]

[env.staging]
vars = { NODE_ENV = "staging" }
routes = [
  { pattern = "staging-api.yourdomain.com/*", zone_id = "your-zone-id" }
]

# Dev environment
[env.dev]
vars = { NODE_ENV = "development" }

# Asset upload (if needed)
[site]
bucket = "./public"